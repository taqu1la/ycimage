# Copy to /etc/ycimage/ycimage.env and chmod 600.
# This file is sourced by bash. Use KEY=VALUE format only; do not quote values.

APP_HOST=127.0.0.1
APP_PORT=4178
YCIMAGE_SERVER_NAME=your-domain.com

# Production mode enables secure cookies and rejects unsafe runtime settings.
YCIMAGE_ENV=production

# Generate a unique value: openssl rand -base64 48
YCIMAGE_SECRET_KEY=replace_with_48_byte_random_secret

# Strong bootstrap password for user_admin. Do not use the legacy default.
YCIMAGE_ADMIN_PASSWORD=replace_with_strong_admin_password_12_chars_min

# Optional break-glass token for local admin automation only.
# Remote X-Admin-Token use is disabled unless YCIMAGE_ADMIN_TOKEN_REMOTE=true.
YCIMAGE_ADMIN_TOKEN=
YCIMAGE_ADMIN_TOKEN_REMOTE=false

# Optional explicit Python path.
YCIMAGE_PYTHON_BIN=python3

# Production database location.
YCIMAGE_DB_PATH=/var/lib/ycimage/app.db
# Optional controlled production seed DB. Leave empty for normal deployments;
# apply_release.sh will not copy backend/data/app.db into production.
YCIMAGE_SEED_DB_PATH=
YCIMAGE_BACKUP_DIR=/opt/ycimage/backups
YCIMAGE_BACKUP_RETENTION_DAYS=7

APIMART_BASE_URL=https://api.apimart.ai
APIMART_API_KEY=replace_with_real_key

# Replace with your real production HTTPS origins only.
YCIMAGE_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

YCIMAGE_ENABLE_MOBILE_AUTH=false
YCIMAGE_ENABLE_WECHAT_MOCK_LOGIN=false
YCIMAGE_DEBUG_AUTH_CODES=false

# Start with manual payment first unless MPAY is confirmed available.
YCIMAGE_PAYMENT_PROVIDER=manual

# Fill these only when you actually enable MPAY. Production callback and return
# URLs must be HTTPS and must point at this backend domain.
MPAY_BASE_URL=
MPAY_PID=
MPAY_KEY=
MPAY_NOTIFY_URL=https://your-domain.com/api/pay/notify/mpay
MPAY_RETURN_URL=https://your-domain.com/account.html
